#!/usr/bin/env bash
# memory-sync skill for Claude Code

SKILL_NAME="memory-sync"
SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SKILL_DIR/lib"

CONFIG_FILE="$HOME/.memory-sync-config"
DEFAULT_REPO_PATH="$HOME/my-memory"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

usage() {
    cat << EOF
Memory Sync - 跨主机全局记忆同步

用法:
  $SKILL_NAME init              # 初始化配置
  $SKILL_NAME sync              # 立即同步记忆到 GitHub
  $SKILL_NAME merge             # 拉取并融合所有主机记忆
  $SKILL_NAME status            # 查看状态
  $SKILL_NAME decrypt <host>    # 解密查看指定主机记忆
  $SKILL_NAME uninstall         # 卸载

示例:
  $SKILL_NAME init
  $SKILL_NAME sync
  $SKILL_NAME merge
  $SKILL_NAME status
  $SKILL_NAME decrypt laptop
EOF
}

# 加载配置
load_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        return 1
    fi

    REPO_PATH=$(jq -r '.repoPath // "'"$DEFAULT_REPO_PATH"'"' "$CONFIG_FILE" | sed "s|^~|$HOME|")
    REPO_URL=$(jq -r '.repoUrl // ""' "$CONFIG_FILE")
    PASSWORD_FILE=$(jq -r '.passwordFile // "~/.my-memory-password"' "$CONFIG_FILE" | sed "s|^~|$HOME|")

    return 0
}

# 初始化
cmd_init() {
    log "初始化 Memory Sync..."

    # 检查是否已配置
    if [ -f "$CONFIG_FILE" ]; then
        warn "配置文件已存在: $CONFIG_FILE"
        read -p "是否重新配置？(y/n) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 0
        fi
    fi

    # 设置密码
    PASSWORD_FILE="$HOME/.my-memory-password"

    if [ -f "$PASSWORD_FILE" ]; then
        log "密码文件已存在，使用现有密码"
    else
        read -s -p "请设置加密密码（至少 8 位）: " password
        echo
        read -s -p "请再次输入密码: " password_confirm
        echo

        if [ "$password" != "$password_confirm" ]; then
            error "两次密码不一致"
            exit 1
        fi

        if [ ${#password} -lt 8 ]; then
            error "密码太短，至少 8 位"
            exit 1
        fi

        echo "$password" > "$PASSWORD_FILE"
        chmod 600 "$PASSWORD_FILE"
        log "✓ 密码已保存"
    fi

    # 设置仓库
    read -p "请输入 my-memory 仓库 URL（如 git@github.com:yinrong/my-memory.git）: " repo_url

    if [ -z "$repo_url" ]; then
        error "仓库 URL 不能为空"
        exit 1
    fi

    # 保存配置
    cat > "$CONFIG_FILE" << EOF
{
  "passwordFile": "$PASSWORD_FILE",
  "repoPath": "$DEFAULT_REPO_PATH",
  "repoUrl": "$repo_url",
  "syncTime": "03:00",
  "mergeTime": "03:30",
  "autoSync": true,
  "autoMerge": true
}
EOF

    log "✓ 配置已保存到: $CONFIG_FILE"

    # 克隆或初始化仓库
    if [ -d "$DEFAULT_REPO_PATH" ]; then
        log "my-memory 仓库已存在: $DEFAULT_REPO_PATH"
    else
        log "克隆 my-memory 仓库..."

        # 尝试克隆
        if git clone "$repo_url" "$DEFAULT_REPO_PATH" 2>/dev/null; then
            log "✓ 仓库克隆成功"
        else
            # 克隆失败，可能是新仓库，初始化
            log "仓库不存在，创建新仓库..."
            mkdir -p "$DEFAULT_REPO_PATH"
            cd "$DEFAULT_REPO_PATH"
            git init
            git branch -m main
            git remote add origin "$repo_url"

            # 创建 README
            cp "$SKILL_DIR/../my-memory-README.md" README.md 2>/dev/null || \
            cat > README.md << 'MDEOF'
# My Memory

跨主机全局记忆同步系统。

由 memory-sync skill 管理。

## 目录结构

\`\`\`
my-memory/
├── README.md
└── hosts/
    ├── <hostname>/       # 加密的记忆文件
    │   ├── *.md.enc
    │   └── metadata.json
    └── common/           # 融合后的公共记忆
        └── *.md
\`\`\`

## 使用

请使用 memory-sync skill 管理此仓库：

\`\`\`bash
/memory-sync init
/memory-sync sync
/memory-sync merge
\`\`\`
MDEOF

            git add README.md
            git commit -m "Initial commit"
            git push -u origin main

            log "✓ 仓库初始化完成"
        fi
    fi

    # 设置定时任务
    read -p "是否添加定时任务（每天 03:00 同步，03:30 融合）？(y/n) " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        CRON_SYNC="0 3 * * * $SKILL_DIR/$SKILL_NAME sync >> $DEFAULT_REPO_PATH/sync.log 2>&1"
        CRON_MERGE="30 3 * * * $SKILL_DIR/$SKILL_NAME merge >> $DEFAULT_REPO_PATH/merge.log 2>&1"

        # 添加到 crontab（如果不存在）
        (crontab -l 2>/dev/null | grep -v "$SKILL_NAME"; echo ""; echo "# Memory Sync"; echo "$CRON_SYNC"; echo "$CRON_MERGE") | crontab -

        log "✓ 定时任务已添加"
    fi

    echo ""
    log "初始化完成！"
    log "下一步："
    echo "  1. 立即同步: /memory-sync sync"
    echo "  2. 拉取融合: /memory-sync merge"
    echo "  3. 查看状态: /memory-sync status"
}

# 同步
cmd_sync() {
    if ! load_config; then
        error "未初始化，请先运行: /memory-sync init"
        exit 1
    fi

    cd "$REPO_PATH" || exit 1
    bash "$LIB_DIR/sync-memory.sh"
}

# 融合
cmd_merge() {
    if ! load_config; then
        error "未初始化，请先运行: /memory-sync init"
        exit 1
    fi

    cd "$REPO_PATH" || exit 1
    bash "$LIB_DIR/pull-and-merge.sh"
}

# 状态
cmd_status() {
    if ! load_config; then
        error "未初始化，请先运行: /memory-sync init"
        exit 1
    fi

    log "Memory Sync 状态"
    echo ""

    # 仓库信息
    echo "仓库路径: $REPO_PATH"
    echo "仓库 URL: $REPO_URL"
    echo ""

    # 本机信息
    HOSTNAME=$(hostname)
    echo "本机主机名: $HOSTNAME"

    if [ -d "$REPO_PATH/hosts/$HOSTNAME" ]; then
        if [ -f "$REPO_PATH/hosts/$HOSTNAME/metadata.json" ]; then
            last_sync=$(jq -r '.last_sync // "unknown"' "$REPO_PATH/hosts/$HOSTNAME/metadata.json")
            file_count=$(jq -r '.file_count // 0' "$REPO_PATH/hosts/$HOSTNAME/metadata.json")
            echo "最后同步: $last_sync"
            echo "文件数量: $file_count"
        fi
    else
        warn "本机尚未同步"
    fi

    echo ""

    # 其他主机
    cd "$REPO_PATH" || exit 1
    git fetch --all --quiet 2>/dev/null || true

    echo "其他主机:"
    git branch -r | grep 'origin/host/' | sed 's|origin/host/||' | while read host; do
        if [ "$host" != "$HOSTNAME" ]; then
            echo "  - $host"
        fi
    done

    # 融合状态
    echo ""
    if git show-ref --verify --quiet "refs/remotes/origin/common"; then
        log "公共记忆已融合（common 分支）"

        if [ -d "$REPO_PATH/hosts/common" ]; then
            file_count=$(find "$REPO_PATH/hosts/common" -name "*.md" | wc -l)
            echo "融合文件数: $file_count"
        fi
    else
        warn "公共记忆尚未融合"
    fi
}

# 解密
cmd_decrypt() {
    if ! load_config; then
        error "未初始化，请先运行: /memory-sync init"
        exit 1
    fi

    if [ $# -eq 0 ]; then
        error "请指定主机名"
        echo "用法: /memory-sync decrypt <hostname>"
        exit 1
    fi

    TARGET_HOST=$1
    cd "$REPO_PATH" || exit 1

    # 切换到对应分支
    git fetch origin "host/$TARGET_HOST" 2>/dev/null || {
        error "主机 $TARGET_HOST 不存在"
        exit 1
    }

    git checkout "host/$TARGET_HOST" 2>/dev/null

    # 解密文件
    HOST_DIR="hosts/$TARGET_HOST"

    if [ ! -d "$HOST_DIR" ]; then
        error "主机目录不存在: $HOST_DIR"
        exit 1
    fi

    log "解密主机 $TARGET_HOST 的记忆:"
    echo ""

    for enc_file in "$HOST_DIR"/*.enc; do
        if [ -f "$enc_file" ]; then
            filename=$(basename "$enc_file" .enc)
            echo "=== $filename ==="

            bash "$LIB_DIR/decrypt-memory.sh" "$enc_file"
            echo ""
        fi
    done

    # 回到 main 分支
    git checkout main 2>/dev/null
}

# 卸载
cmd_uninstall() {
    warn "准备卸载 Memory Sync..."
    read -p "是否继续？(y/n) " -n 1 -r
    echo

    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 0
    fi

    # 删除定时任务
    crontab -l 2>/dev/null | grep -v "$SKILL_NAME" | crontab -
    log "✓ 已删除定时任务"

    # 删除配置
    if [ -f "$CONFIG_FILE" ]; then
        rm "$CONFIG_FILE"
        log "✓ 已删除配置: $CONFIG_FILE"
    fi

    # 询问是否删除仓库
    read -p "是否删除 my-memory 本地仓库？(y/n) " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]] && load_config; then
        rm -rf "$REPO_PATH"
        log "✓ 已删除仓库: $REPO_PATH"
    fi

    log "卸载完成"
    log "注意: GitHub 上的 my-memory 仓库未删除（作为备份）"
}

# 主逻辑
main() {
    if [ $# -eq 0 ]; then
        usage
        exit 0
    fi

    COMMAND=$1
    shift

    case "$COMMAND" in
        init)
            cmd_init "$@"
            ;;
        sync)
            cmd_sync "$@"
            ;;
        merge)
            cmd_merge "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        decrypt)
            cmd_decrypt "$@"
            ;;
        uninstall)
            cmd_uninstall "$@"
            ;;
        *)
            error "未知命令: $COMMAND"
            usage
            exit 1
            ;;
    esac
}

main "$@"
