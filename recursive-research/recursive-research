#!/usr/bin/env bash
# recursive-research skill for Claude Code

SKILL_NAME="recursive-research"
RESEARCH_BASE_DIR="调研"

# 显示使用帮助
show_usage() {
    cat << EOF
递归式深度调研 (recursive-research)

用法:
  $SKILL_NAME <研究主题>              # 新建调研
  $SKILL_NAME --resume <研究ID>      # 继续已有调研

示例:
  $SKILL_NAME "分布式训练方案对比"
  $SKILL_NAME --resume 分布式训练方案对比
EOF
}

# 主逻辑
main() {
    if [ $# -eq 0 ]; then
        show_usage
        exit 1
    fi

    if [ "$1" = "--resume" ]; then
        if [ -z "$2" ]; then
            echo "错误：--resume 需要指定研究ID"
            exit 1
        fi
        RESUME_MODE=true
        RESEARCH_ID="$2"
    else
        RESUME_MODE=false
        RESEARCH_TOPIC="$*"
        # 生成研究ID：日期-主题
        RESEARCH_ID="$(date +%Y-%m-%d)-${RESEARCH_TOPIC// /-}"
    fi

    RESEARCH_DIR="$RESEARCH_BASE_DIR/$RESEARCH_ID"

    if [ "$RESUME_MODE" = true ]; then
        if [ ! -d "$RESEARCH_DIR" ]; then
            echo "错误：找不到研究目录 $RESEARCH_DIR"
            exit 1
        fi
        echo "从检查点恢复调研：$RESEARCH_ID"
    else
        mkdir -p "$RESEARCH_DIR"
        echo "开始新调研：$RESEARCH_TOPIC"
        echo "输出目录：$RESEARCH_DIR"
    fi

    # 调用 Claude 执行调研任务
    cat << EOF

---

# 任务：递归式深度调研

$(if [ "$RESUME_MODE" = true ]; then
    echo "## 续传模式"
    echo ""
    echo "从以下目录加载之前的调研状态："
    echo "\`$RESEARCH_DIR\`"
    echo ""
    echo "请读取以下文件恢复上下文："
    echo "1. \`$RESEARCH_DIR/状态.md\` - 当前进度"
    echo "2. \`$RESEARCH_DIR/线索.md\` - 研究线索"
    echo "3. \`$RESEARCH_DIR/发现.md\` - 已有发现"
    echo "4. 最新的 \`$RESEARCH_DIR/轮次-*.md\` - 上一轮记录"
    echo ""
    echo "然后继续下一轮调研。"
else
    echo "## 新建调研"
    echo ""
    echo "**主题**：$RESEARCH_TOPIC"
    echo "**输出目录**：\`$RESEARCH_DIR\`"
    echo ""
    echo "### 初始化步骤"
    echo ""
    echo "1. **询问配置**："
    echo "   - 研究模式：网络搜索 / 本地文档 / 混合模式"
    echo "   - 来源偏好：中文优先 / 英文优先 / 双语"
    echo "   - 最大轮次：建议 10-20 轮（防止无限循环）"
    echo ""
    echo "2. **拆解线索**：基于主题识别 3-5 条核心研究线索"
    echo ""
    echo "3. **开始第一轮调研**"
fi)

---

## 调研流程（每轮执行）

**核心原则：文档驱动调研（先写后搜）+ 自动连续迭代**

和 code-iteration 相同：先写计划（为什么搜这个方向），再搜集，最后审查。
**禁止"搜10个来源不写分析就跳下一轮"**——每轮必须完成全部步骤才能进入下一轮。

**⚡ 自动继续规则：完成一轮后如果未达标，立即开始下一轮，不要停下来询问用户。**
**只在以下情况才停下来向用户汇报并等待指示：**
1. 达标判定三维度全部满足
2. 达到最大轮次
3. 遇到无法自行解决的阻塞（需要用户提供信息/权限/决策）
4. 隐含假设审计中发现需要用户确认的重大方向性问题

除上述 4 种情况外，AI 必须自主循环调研，不得中断等待用户。

### 步骤 1: [写] 本轮计划（搜集前必须完成）⛔ GATE

在 \`轮次-XX.md\` 中先写：

\`\`\`markdown
## 本轮计划

**目标线索**：<线索名称>
**选择理由**：为什么选这条线索（不能只说"覆盖度最低"）
**搜索策略**：
- 打算搜什么关键词 / 去哪里找
- 期望找到什么类型的信息
- 什么信号说明这个方向搜够了

**预期发现**：<搜之前的假设——期望验证/推翻什么>
**可能的偏差**：<我可能倾向于找支持什么观点的来源？>

### 隐含假设审计 [强制]

列出本轮中所有"我默认为真、不打算验证"的前提：

| # | 假设 | 为什么我认为不需要验证 | 如果错了的后果 | 决定 |
|---|------|----------------------|--------------|------|
| 1 | ... | ... | ... | 验证/接受风险 |
| 2 | ... | ... | ... | ... |

规则：
- ≥3 条（少于 3 条说明没认真想）
- "上轮就是这样搜的"不是有效理由
- "没想过"= 必须验证

常见隐含假设举例：
- 上轮的来源评估标准仍然适用
- 上轮的关键词能覆盖本轮线索
- 某领域的最新进展和 N 年前一样
- 中文/英文来源的观点分布一致
\`\`\`

**⛔ GATE：计划（含隐含假设审计）未写完，不得开始搜索。**

### 步骤 2: [做] 搜集并评估来源

- 搜索相关资料（网络/本地）
- 按标准分级（T1/T2/T3/拒绝）
- 记录来源元信息：标题、URL/路径、作者、发布时间
- **主动搜索反面证据**——不能只找支持初始假设的来源

### 步骤 3: [写] 发现记录 + 实际 vs 预期

\`\`\`markdown
## 关键发现

1. **发现 1**：<内容> [来源：标题]
2. **发现 2**：<内容> [来源：标题]

## 实际 vs 预期
| 维度 | 搜前假设 | 实际发现 | 差异分析 |
|------|----------|----------|----------|
| ... | ... | ... | 为什么不同？|

## 意外发现
<搜之前没预想到的信息>
\`\`\`

### 步骤 4: [写] 对抗性审查 ⛔ GATE

\`\`\`markdown
## 对抗性审查 [强制]

### 3 个破坏性问题
1. "这些发现可能错在哪？有没有我忽略的反面证据？" → <回答>
2. "我是否只找了支持初始假设的来源？是否存在选择性偏差？" → <回答>
3. "如果把 T1 来源降一级重新评估，结论还成立吗？" → <回答>

### 覆盖度真实性
- 找到的来源是否互相独立？（10篇引用同一原始研究 ≠ 10个独立证据）
- 广度 vs 深度：覆盖了几个不同视角？
- 是否有意避开了某些方向？

### 搜索方向修正
- 基于本轮审查，下一轮是否需要改变搜索方向？
- 有没有需要主动寻找的反面证据？
\`\`\`

**⛔ GATE：对抗性审查未完成，不得进入下一轮。**

### 步骤 5: 更新知识库 + 达标检查

更新以下文件：
\`\`\`
$RESEARCH_DIR/
├── 状态.md              # 更新当前轮次、覆盖度、下一步
├── 线索.md              # 更新线索覆盖度
├── 发现.md              # 追加本轮发现（按线索分组）
├── 来源-T*.md           # 追加新来源
├── 轮次-XX.md           # 本轮完整记录（含计划+结果+审查）
\`\`\`

**达标检查**（必须同时满足三个维度）：

**广度达标**：
- [ ] 所有线索覆盖度 ≥80%
- [ ] 每条线索 ≥3 个**独立** T1 来源（引用同一原始研究的不算独立）
- [ ] 连续 3 轮新发现饱和度 ≤5%

**质量达标**：
- [ ] 已主动搜索并记录反面证据
- [ ] 存在 ≥3 个跨线索连接
- [ ] 关键结论有 ≥2 个独立来源交叉验证

**诚实性达标**：
- [ ] 已声明研究的适用范围和盲区
- [ ] 已声明哪些结论是强共识、哪些是弱假设
- [ ] "知识缺口" 文件已填写

**判断**：
- ✅ **三维度全部满足** → 生成最终报告
- ⚠️ **广度达标但质量/诚实性不足** → 补充反面证据轮
- ⏳ **广度未达标** → 继续下一轮
- ⛔ **达到最大轮次** → 生成不完整报告 + 声明局限性

---

## 最终报告（达标后生成）

### 综合报告.md

**要求**：三层结构——不懂的人看完能理解领域背景并形成判断。
**检验标准**：一个不了解本主题的同事，只看这份报告，能向第三方正确解释核心结论及其依据。

\`\`\`markdown
# <主题> 综合报告

**调研周期**：YYYY-MM-DD ~ YYYY-MM-DD
**总轮次**：X 轮
**来源统计**：T1=X, T2=Y, T3=Z

## 一、背景与原理（为什么研究这个）

### 问题定义
<解决什么问题、为什么重要、谁关心>

### 领域地图
<这个领域有哪些关键概念、它们之间什么关系>

\\\`\\\`\\\`mermaid
graph TD
  A[概念A] -->|关系| B[概念B]
\\\`\\\`\\\`

## 二、核心发现（是什么）

### 线索 1：<名称>

**一句话结论**：<这条线索最重要的发现>
**证据强度**：强共识 / 弱假设 / 有争议
**核心发现**：
1. ...（[来源](URL) T1）
2. ...

### 线索 2：...

### 跨线索洞察
1. **洞察 1**：<连接线索 A 和 B 的发现>

## 三、适用范围与限制 [强制]

### 本研究覆盖了什么
- <列举已充分调研的方面>

### 本研究没覆盖什么（盲区）
- <列举已知但未深入的方面>
- <列举可能存在但未搜索的方向>

### 结论的可靠性分级
| 结论 | 可靠性 | 依据数量 | 争议程度 |
|------|--------|----------|----------|
| 结论A | 强共识 | 5个独立T1 | 无争议 |
| 结论B | 弱假设 | 2个T2 | 有反面证据 |

### 失效条件
- <什么情况下这些结论不再适用>
- <什么新信息出现时需要重新调研>

## 四、逆向审视

- 被拒绝的假设：...
- 潜在风险/反面证据：...
- 认知盲区：...
- 搜索偏差声明：...

## 参考文献

