#!/usr/bin/env bash
# recursive-research skill for Claude Code

SKILL_NAME="recursive-research"
RESEARCH_BASE_DIR="调研"

# 显示使用帮助
show_usage() {
    cat << EOF
递归式深度调研 (recursive-research)

用法:
  $SKILL_NAME <研究主题>              # 新建调研
  $SKILL_NAME --resume <研究ID>      # 继续已有调研

示例:
  $SKILL_NAME "分布式训练方案对比"
  $SKILL_NAME --resume 分布式训练方案对比
EOF
}

# 主逻辑
main() {
    if [ $# -eq 0 ]; then
        show_usage
        exit 1
    fi

    if [ "$1" = "--resume" ]; then
        if [ -z "$2" ]; then
            echo "错误：--resume 需要指定研究ID"
            exit 1
        fi
        RESUME_MODE=true
        RESEARCH_ID="$2"
    else
        RESUME_MODE=false
        RESEARCH_TOPIC="$*"
        # 生成研究ID：日期-主题
        RESEARCH_ID="$(date +%Y-%m-%d)-${RESEARCH_TOPIC// /-}"
    fi

    RESEARCH_DIR="$RESEARCH_BASE_DIR/$RESEARCH_ID"

    if [ "$RESUME_MODE" = true ]; then
        if [ ! -d "$RESEARCH_DIR" ]; then
            echo "错误：找不到研究目录 $RESEARCH_DIR"
            exit 1
        fi
        echo "从检查点恢复调研：$RESEARCH_ID"
    else
        mkdir -p "$RESEARCH_DIR"
        echo "开始新调研：$RESEARCH_TOPIC"
        echo "输出目录：$RESEARCH_DIR"
    fi

    # 调用 Claude 执行调研任务
    cat << EOF

---

# 任务：递归式深度调研

$(if [ "$RESUME_MODE" = true ]; then
    echo "## 续传模式"
    echo ""
    echo "从以下目录加载之前的调研状态："
    echo "\`$RESEARCH_DIR\`"
    echo ""
    echo "请读取以下文件恢复上下文："
    echo "1. \`$RESEARCH_DIR/状态.md\` - 当前进度"
    echo "2. \`$RESEARCH_DIR/线索.md\` - 研究线索"
    echo "3. \`$RESEARCH_DIR/发现.md\` - 已有发现"
    echo "4. 最新的 \`$RESEARCH_DIR/轮次-*.md\` - 上一轮记录"
    echo ""
    echo "然后继续下一轮调研。"
else
    echo "## 新建调研"
    echo ""
    echo "**主题**：$RESEARCH_TOPIC"
    echo "**输出目录**：\`$RESEARCH_DIR\`"
    echo ""
    echo "### 初始化步骤"
    echo ""
    echo "1. **询问配置**："
    echo "   - 研究模式：网络搜索 / 本地文档 / 混合模式"
    echo "   - 来源偏好：中文优先 / 英文优先 / 双语"
    echo "   - 最大轮次：建议 10-20 轮（防止无限循环）"
    echo ""
    echo "2. **拆解线索**：基于主题识别 3-5 条核心研究线索"
    echo ""
    echo "3. **开始第一轮调研**"
fi)

---

## 调研流程（每轮执行）

### 1. 选择线索
- 选择覆盖度最低的线索
- 使用 WDM 评估：信息缺口、来源可得性、关联性

### 2. 搜集来源
- 搜索相关资料（网络/本地）
- 按标准分级（T1/T2/T3/拒绝）
- 记录来源元信息：标题、URL/路径、作者、发布时间

### 3. 提取发现
- 阅读/分析来源内容
- 提取关键事实、数据、观点
- 标注来源引用

### 4. 更新知识库
更新以下文件：

\`\`\`
$RESEARCH_DIR/
├── 状态.md              # 更新当前轮次、覆盖度、下一步
├── 线索.md              # 更新线索覆盖度
├── 发现.md              # 追加本轮发现（按线索分组）
├── 来源-T*.md           # 追加新来源
├── 轮次-XX.md           # 创建本轮完整记录
\`\`\`

**轮次记录格式**（\`轮次-XX.md\`）：

\`\`\`markdown
# 第 X 轮调研

**时间**：YYYY-MM-DD HH:MM
**目标线索**：<线索名称>
**覆盖度变化**：X% → Y%

## 本轮来源

| 标题 | 等级 | 类型 | URL/路径 |
|------|------|------|----------|
| ... | T1 | 论文 | https://... |

## 关键发现

1. **发现 1**：<内容> [来源：标题]
2. **发现 2**：<内容> [来源：标题]

## 逆向思考

- 这些发现可能错在哪？
- 我遗漏了什么反面证据？
- 是否存在选择性偏差？

## 下一步

- 下一个优先线索：<线索名称>
- 需要验证的假设：...
\`\`\`

### 5. 达标检查

每轮结束后检查是否满足所有条件：

- [ ] 所有线索覆盖度 ≥80%
- [ ] 每条线索 ≥3 个 T1 来源
- [ ] 连续 3 轮新发现饱和度 ≤5%
- [ ] 已应用芒格逆向思考
- [ ] 存在 ≥3 个跨线索连接

**未达标** → 继续下一轮
**已达标** → 生成最终报告

---

## 最终报告（达标后生成）

### 综合报告.md

\`\`\`markdown
# <主题> 综合报告

**调研周期**：YYYY-MM-DD ~ YYYY-MM-DD
**总轮次**：X 轮
**来源统计**：T1=X, T2=Y, T3=Z

## 执行摘要

<3-5 段核心结论>

## 研究线索

### 线索 1：<名称>

**覆盖度**：95%
**核心发现**：
1. ...
2. ...

**关键来源**：
- [来源标题](URL) (T1)

### 线索 2：...

## 跨线索洞察

1. **洞察 1**：<连接线索 A 和 B 的发现>
2. ...

## 逆向审视

- 被拒绝的假设：...
- 潜在风险：...
- 认知盲区：...

## 知识图谱

\`\`\`mermaid
graph TD
  A[线索1] -->|关联| B[线索2]
  A -->|验证| C[发现X]
\`\`\`

## 参考文献

### T1 级来源（权威）
1. ...

### T2 级来源（可靠）
...
\`\`\`

### 行动建议.md

\`\`\`markdown
# 行动建议

基于调研结果，建议采取以下行动：

## 立即可行
1. **行动 1**：<具体操作> [依据：发现 X]
2. ...

## 需验证后执行
1. **行动 A**：<操作> [待验证：假设 Y]

## 长期跟进
...
\`\`\`

### 知识缺口.md

\`\`\`markdown
# 知识缺口

调研中发现但未能充分解答的问题：

## 高优先级
1. **问题 1**：<描述>
   - **为什么重要**：...
   - **建议方向**：...

## 中优先级
...

## 低优先级（可忽略）
...
\`\`\`

---

## 注意事项

1. **所有文件使用中文、Markdown、UTF-8 编码**
2. **每轮必须保存检查点**（更新状态.md + 创建轮次-XX.md）
3. **来源引用格式统一**：\`[标题](URL/路径) (T1/T2/T3)\`
4. **逆向思考不能省略**：每轮必须质疑自己的发现
5. **超过最大轮次未达标时**：生成不完整报告 + 说明原因

---

**开始执行调研任务**
EOF
}

main "$@"
