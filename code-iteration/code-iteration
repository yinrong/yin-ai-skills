#!/usr/bin/env bash
# code-iteration skill for Claude Code

SKILL_NAME="code-iteration"
EXP_BASE_DIR="实验"

# 显示使用帮助
show_usage() {
    cat << EOF
代码持续迭代 (code-iteration)

用法:
  $SKILL_NAME <实验名称> "<目标描述>"     # 新建实验
  $SKILL_NAME --resume <实验ID>         # 继续实验

示例:
  $SKILL_NAME "优化器对比" "实现并对比 Adam/SGD 在 MNIST 上的性能"
  $SKILL_NAME --resume 优化器对比
EOF
}

# 主逻辑
main() {
    if [ $# -eq 0 ]; then
        show_usage
        exit 1
    fi

    if [ "$1" = "--resume" ]; then
        if [ -z "$2" ]; then
            echo "错误：--resume 需要指定实验ID"
            exit 1
        fi
        RESUME_MODE=true
        EXP_ID="$2"
    else
        RESUME_MODE=false
        EXP_NAME="$1"
        EXP_GOAL="${2:-}"

        if [ -z "$EXP_GOAL" ]; then
            echo "错误：缺少目标描述"
            show_usage
            exit 1
        fi

        # 生成实验ID：日期-名称
        EXP_ID="$(date +%Y-%m-%d)-${EXP_NAME// /-}"
    fi

    EXP_DIR="$EXP_BASE_DIR/$EXP_ID"

    if [ "$RESUME_MODE" = true ]; then
        if [ ! -d "$EXP_DIR" ]; then
            echo "错误：找不到实验目录 $EXP_DIR"
            exit 1
        fi
        echo "从检查点恢复实验：$EXP_ID"
    else
        mkdir -p "$EXP_DIR"/{检查点,迭代日志,代码,结果}
        echo "开始新实验：$EXP_NAME"
        echo "输出目录：$EXP_DIR"
    fi

    # 调用 Claude 执行迭代任务
    cat << EOF

---

# 任务：代码持续迭代

$(if [ "$RESUME_MODE" = true ]; then
    echo "## 续传模式"
    echo ""
    echo "从以下目录加载实验状态："
    echo "\`$EXP_DIR\`"
    echo ""
    echo "### 恢复步骤"
    echo ""
    echo "1. **读取索引**：\`$EXP_DIR/README.md\`"
    echo "2. **读取当前状态**：\`$EXP_DIR/当前状态.md\`"
    echo "3. **读取最新检查点**：\`$EXP_DIR/检查点/<最新>.md\`"
    echo "4. **读取最近 3 轮日志**：\`$EXP_DIR/迭代日志/第XX轮-*.md\`"
    echo "5. **读取目标**：\`$EXP_DIR/目标与标准.md\`"
    echo ""
    echo "然后从"下一步"继续执行。"
else
    echo "## 新建实验"
    echo ""
    echo "**实验名称**：$EXP_NAME"
    echo "**目标**：$EXP_GOAL"
    echo "**输出目录**：\`$EXP_DIR\`"
    echo ""
    echo "### 初始化步骤"
    echo ""
    echo "1. **询问详细配置**："
    echo "   - **成功标准**：如何判定实验完成？（例如：准确率 >95%，性能提升 2 倍，通过所有单元测试）"
    echo "   - **约束条件**：时间限制（如 1 天内）、资源限制（仅 CPU）、必须使用的技术栈"
    echo "   - **验证方式**：自动测试 / 手动检查 / 可视化验证"
    echo "   - **最大迭代轮次**：建议 20-50 轮（防止无限循环）"
    echo ""
    echo "2. **创建初始文件**："
    echo "   - \`目标与标准.md\`：记录用户回答的配置"
    echo "   - \`当前状态.md\`：初始状态（第 0 轮）"
    echo "   - \`README.md\`：索引文件（初始版）"
    echo "   - \`复现指南.md\`：空白模板（后续补充）"
    echo "   - \`决策树.md\`：空白 Mermaid 图（后续补充）"
    echo "   - \`失败案例库.md\`：空白（记录失败）"
    echo "   - \`发现与洞察.md\`：空白（记录意外发现）"
    echo ""
    echo "3. **开始第 1 轮迭代**"
fi)

